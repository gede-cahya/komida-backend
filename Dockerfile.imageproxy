FROM golang:1.25-bookworm AS builder

WORKDIR /src
COPY go.mod go.sum ./
COPY cmd ./cmd
COPY internal ./internal
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/komida-imageproxy ./cmd/imageproxy

FROM gcr.io/distroless/static-debian12:nonroot

WORKDIR /app
COPY --from=builder /out/komida-imageproxy /app/komida-imageproxy
EXPOSE 3482
ENTRYPOINT ["/app/komida-imageproxy"]
